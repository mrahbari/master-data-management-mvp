{
  "info": {
    "name": "MDM MVP API",
    "description": "Master Data Management API collection for testing with OAuth2 JWT tokens",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{access_token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string"
    },
    {
      "key": "oauth_url",
      "value": "http://localhost:9999",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/actuator/health",
          "host": ["{{base_url}}"],
          "path": ["actuator", "health"]
        },
        "description": "Check service health status (no auth required)"
      }
    },
    {
      "name": "Create Customer (Admin)",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"sourceSystem\": \"postman-test\",\n  \"metadata\": {\n    \"channel\": \"web\",\n    \"campaign\": \"test-campaign\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/customers",
          "host": ["{{base_url}}"],
          "path": ["api", "customers"]
        },
        "description": "Create a new customer record. Requires CUSTOMER_WRITE or ADMIN role."
      }
    },
    {
      "name": "Get All Customers",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/customers",
          "host": ["{{base_url}}"],
          "path": ["api", "customers"]
        },
        "description": "Retrieve all customer records. Requires CUSTOMER_READ or ADMIN role."
      }
    },
    {
      "name": "Get Customer by ID",
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{access_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/customers/:id",
          "host": ["{{base_url}}"],
          "path": ["api", "customers", ":id"],
          "variable": [
            {
              "key": "id",
              "value": "1"
            }
          ]
        },
        "description": "Retrieve a specific customer by ID. Requires CUSTOMER_READ or ADMIN role."
      }
    },
    {
      "name": "Get Token - Admin",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"mdm-client\",\n  \"client_secret\": \"mdm-secret\",\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
        },
        "url": {
          "raw": "{{oauth_url}}/oauth/token",
          "host": ["{{oauth_url}}"],
          "port": "",
          "path": ["oauth", "token"]
        },
        "description": "Get JWT token for admin user (ADMIN, CUSTOMER_WRITE, CUSTOMER_READ roles). Copy the access_token and set it in the collection variable."
      }
    },
    {
      "name": "Get Token - User (Write)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"mdm-client\",\n  \"client_secret\": \"mdm-secret\",\n  \"username\": \"user\",\n  \"password\": \"user123\"\n}"
        },
        "url": {
          "raw": "{{oauth_url}}/oauth/token",
          "host": ["{{oauth_url}}"],
          "port": "",
          "path": ["oauth", "token"]
        },
        "description": "Get JWT token for regular user (CUSTOMER_WRITE role only)."
      }
    },
    {
      "name": "Get Token - ReadOnly",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"grant_type\": \"password\",\n  \"client_id\": \"mdm-client\",\n  \"client_secret\": \"mdm-secret\",\n  \"username\": \"readonly\",\n  \"password\": \"readonly123\"\n}"
        },
        "url": {
          "raw": "{{oauth_url}}/oauth/token",
          "host": ["{{oauth_url}}"],
          "port": "",
          "path": ["oauth", "token"]
        },
        "description": "Get JWT token for read-only user (CUSTOMER_READ role only)."
      }
    }
  ]
}
