<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <springProperty name="LOG_PATH" source="logging.file.path" defaultValue="/app/logs"/>

    <!-- Main application log file -->
    <appender name="MAIN_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_PATH}/mastering.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Conflict resolution log file -->
    <appender name="CONFLICT_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_PATH}/conflict-resolution.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Retry log file -->
    <appender name="RETRY_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_PATH}/retries.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- DLQ log file -->
    <appender name="DLQ_FILE" class="ch.qos.logback.core.FileAppender">
        <file>${LOG_PATH}/dlq.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Conflict Resolution logger -->
    <logger name="com.mdm.mastering.conflict" level="INFO" additivity="false">
        <appender-ref ref="CONFLICT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Retry logger -->
    <logger name="com.mdm.mastering.retry" level="INFO" additivity="false">
        <appender-ref ref="RETRY_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- DLQ logger -->
    <logger name="com.mdm.mastering.dlq" level="INFO" additivity="false">
        <appender-ref ref="DLQ_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- Root logger -->
    <root level="INFO">
        <appender-ref ref="MAIN_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
