#!/bin/bash
set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Script directory
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"

echo -e "${BLUE}========================================${NC}"
echo -e "${BLUE}  MDM MVP - Pre-Commit Hook${NC}"
echo -e "${BLUE}========================================${NC}"
echo ""

# Track overall status
FAILED=0

# Function to print status
print_status() {
    echo -e "${BLUE}[INFO]${NC} $1"
}

print_success() {
    echo -e "${GREEN}[PASS]${NC} $1"
}

print_error() {
    echo -e "${RED}[FAIL]${NC} $1"
}

print_warning() {
    echo -e "${YELLOW}[WARN]${NC} $1"
}

# Get list of staged Java files
STAGED_JAVA_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.java$' || true)
STAGED_GRADLE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.gradle$' || true)
STAGED_YAML_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.yml$\|\.yaml$' || true)

# ===========================================
# Step 1: Check for code formatting (Spotless)
# ===========================================
echo ""
print_status "Checking code formatting (Spotless)..."

if [ -n "$STAGED_JAVA_FILES" ] || [ -n "$STAGED_GRADLE_FILES" ]; then
    # Check each service directory
    for service_dir in "customer-ingestion-service" "customer-mastering-service"; do
        if [ -d "$PROJECT_DIR/$service_dir" ]; then
            cd "$PROJECT_DIR/$service_dir"
            
            # Run spotless check
            if ./gradlew spotlessCheck --quiet --no-daemon > /dev/null 2>&1; then
                print_success "[$service_dir] Code formatting OK"
            else
                print_error "[$service_dir] Code formatting failed"
                print_warning "Run './gradlew spotlessApply' to fix formatting issues"
                FAILED=1
            fi
        fi
    done
else
    print_success "No Java/Gradle files staged, skipping formatting check"
fi

# ===========================================
# Step 2: Run Checkstyle on changed files
# ===========================================
echo ""
print_status "Running Checkstyle on changed files..."

if [ -n "$STAGED_JAVA_FILES" ]; then
    for service_dir in "customer-ingestion-service" "customer-mastering-service"; do
        if [ -d "$PROJECT_DIR/$service_dir" ]; then
            cd "$PROJECT_DIR/$service_dir"
            
            # Check if any staged files belong to this service
            SERVICE_FILES=$(echo "$STAGED_JAVA_FILES" | grep "^$service_dir/" | sed "s/^$service_dir\///" || true)
            
            if [ -n "$SERVICE_FILES" ]; then
                # Run checkstyle on main source
                MAIN_FILES=$(echo "$SERVICE_FILES" | grep "^src/main/" | sed 's/^src\/main\/java\///' || true)
                if [ -n "$MAIN_FILES" ]; then
                    if ./gradlew checkstyleMain --quiet --no-daemon > /dev/null 2>&1; then
                        print_success "[$service_dir] Checkstyle main OK"
                    else
                        print_error "[$service_dir] Checkstyle main failed"
                        FAILED=1
                    fi
                fi
                
                # Run checkstyle on test source
                TEST_FILES=$(echo "$SERVICE_FILES" | grep "^src/test/" | sed 's/^src\/test\/java\///' || true)
                if [ -n "$TEST_FILES" ]; then
                    if ./gradlew checkstyleTest --quiet --no-daemon > /dev/null 2>&1; then
                        print_success "[$service_dir] Checkstyle test OK"
                    else
                        print_error "[$service_dir] Checkstyle test failed"
                        FAILED=1
                    fi
                fi
            fi
        fi
    done
else
    print_success "No Java files staged, skipping Checkstyle"
fi

# ===========================================
# Step 3: Run unit tests for changed modules
# ===========================================
echo ""
print_status "Running unit tests for changed modules..."

RUN_TESTS=false

if [ -n "$STAGED_JAVA_FILES" ]; then
    # Check if files are in test directories or main directories
    for service_dir in "customer-ingestion-service" "customer-mastering-service"; do
        SERVICE_FILES=$(echo "$STAGED_JAVA_FILES" | grep "^$service_dir/" || true)
        if [ -n "$SERVICE_FILES" ]; then
            RUN_TESTS=true
            break
        fi
    done
fi

if [ "$RUN_TESTS" = true ]; then
    for service_dir in "customer-ingestion-service" "customer-mastering-service"; do
        if [ -d "$PROJECT_DIR/$service_dir" ]; then
            cd "$PROJECT_DIR/$service_dir"
            
            SERVICE_FILES=$(echo "$STAGED_JAVA_FILES" | grep "^$service_dir/" || true)
            
            if [ -n "$SERVICE_FILES" ]; then
                print_status "Running tests for $service_dir..."
                
                if ./gradlew test --quiet --no-daemon > /dev/null 2>&1; then
                    print_success "[$service_dir] Tests passed"
                else
                    print_error "[$service_dir] Tests failed"
                    print_warning "Run './gradlew test' to see detailed test results"
                    FAILED=1
                fi
            fi
        fi
    done
else
    print_success "No relevant files staged, skipping tests"
fi

# ===========================================
# Step 4: Check for sensitive data
# ===========================================
echo ""
print_status "Checking for sensitive data..."

SENSITIVE_PATTERNS=(
    "password\s*=\s*['\"][^'\"]+['\"]"
    "secret\s*=\s*['\"][^'\"]+['\"]"
    "api_key\s*=\s*['\"][^'\"]+['\"]"
    "AWS_SECRET"
    "PRIVATE_KEY"
)

SENSITIVE_FOUND=false

for file in $(git diff --cached --name-only); do
    if [[ "$file" != *.env* && "$file" != *secret* && "$file" != *application-local* ]]; then
        for pattern in "${SENSITIVE_PATTERNS[@]}"; do
            if git diff --cached "$file" | grep -iE "$pattern" > /dev/null 2>&1; then
                print_warning "Possible sensitive data in $file (pattern: $pattern)"
                SENSITIVE_FOUND=true
            fi
        done
    fi
done

if [ "$SENSITIVE_FOUND" = false ]; then
    print_success "No sensitive data detected"
fi

# ===========================================
# Step 5: Check commit message format
# ===========================================
echo ""
print_status "Validating commit message format..."

COMMIT_MSG_FILE="$1"
if [ -n "$COMMIT_MSG_FILE" ]; then
    COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")
    
    # Check for conventional commit format (optional, just warn)
    if ! echo "$COMMIT_MSG" | grep -E "^(feat|fix|docs|style|refactor|test|chore|perf|ci|build|revert)(\(.+\))?: " > /dev/null 2>&1; then
        print_warning "Consider using conventional commit format:"
        print_warning "  feat: add new feature"
        print_warning "  fix: fix bug"
        print_warning "  docs: update documentation"
        # Don't fail, just warn
    else
        print_success "Commit message format OK"
    fi
else
    print_success "Skipping commit message validation (not in commit-msg hook)"
fi

# ===========================================
# Summary
# ===========================================
echo ""
echo -e "${BLUE}========================================${NC}"

if [ $FAILED -eq 0 ]; then
    echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
    echo ""
    exit 0
else
    echo -e "${RED}✗ Pre-commit checks failed!${NC}"
    echo ""
    echo -e "${YELLOW}Please fix the issues above and try again.${NC}"
    echo ""
    echo -e "${BLUE}Helpful commands:${NC}"
    echo "  ./gradlew spotlessApply    # Fix code formatting"
    echo "  ./gradlew checkstyleMain   # Check code style"
    echo "  ./gradlew test             # Run tests"
    echo ""
    exit 1
fi
